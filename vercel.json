{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "framework": "vite",
  "cleanUrls": false,
  "rewrites": [
    { "source": "/mapa", "destination": "/" },
    { "source": "/rota", "destination": "/" },
    { "source": "/participantes", "destination": "/" },
    { "source": "/premiacao", "destination": "/" },
    { "source": "/lovers/:path*", "destination": "/" }
  ]
}
